---
/**
 * EDIT HERE:
 * - name, role, university
 * - bio paragraph
 * - photo: swap the "NS" initials for <img src="/photos/profile.jpg" alt="..." />
 * - email link
 */
---
<style>
  .hero { padding: 80px 0 64px; border-bottom: 1px solid var(--border); }
  .hero-inner { display: grid; grid-template-columns: 1fr 180px; gap: 48px; align-items: center; }
  .hero-pill {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 12px; font-weight: 500; letter-spacing: 0.05em; text-transform: uppercase;
    color: var(--amber-600); background: var(--amber-50); border: 1px solid var(--amber-100);
    border-radius: 99px; padding: 4px 14px; margin-bottom: 20px;
  }
  .hero-pill::before { content:''; width:6px; height:6px; border-radius:50%; background:var(--amber-200); }
  .hero h1 { margin-bottom: 6px; }
  .hero-role { font-size: 15px; color: var(--text-secondary); margin-bottom: 20px; font-family: var(--font-body); }
  .hero-bio { font-size: 15px; line-height: 1.8; max-width: 520px; margin-bottom: 32px; }
  .hero-ctas { display: flex; gap: 10px; flex-wrap: wrap; }
  .btn {
    display: inline-flex; align-items: center; gap: 6px;
    font-family: var(--font-body); font-size: 13px; font-weight: 500;
    padding: 9px 20px; border-radius: var(--radius-md); border: 1px solid var(--border);
    cursor: pointer; transition: all 0.15s; text-decoration: none;
  }
  .btn-primary { background: var(--amber-200); color: var(--amber-900); border-color: var(--amber-200); }
  .btn-primary:hover { background: var(--amber-100); }
  .btn-ghost { background: transparent; color: var(--text-secondary); }
  .btn-ghost:hover { background: var(--bg-muted); color: var(--text-primary); border-color: var(--border-hover); }
  .avatar {
    width: 160px; height: 160px; border-radius: var(--radius-xl);
    background: var(--amber-50); border: 1px solid var(--amber-100);
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-display); font-size: 3rem; color: var(--amber-600); justify-self: end;
  }
  .avatar img { width: 100%; height: 100%; object-fit: cover; border-radius: var(--radius-xl); }
  @media (max-width: 640px) {
    .hero-inner { grid-template-columns: 1fr; }
    .avatar { display: none; }
  }
</style>

<section class="hero">
  <div class="hero-inner">
    <div>
      <div class="hero-pill">Human-centered AI</div>
      <h1>Md. Nazmus Sakib</h1>
      <p class="hero-role">PhD Researcher · Human-AI Interaction · [Your University]</p>
      <p class="hero-bio">
        I design, build, and study AI systems that genuinely work <em>with</em> people.
        My research asks: how do humans make sense of AI, and how can we design
        interactions that feel trustworthy, transparent, and human?
      </p>
      <div class="hero-ctas">
        <a href="/research" class="btn btn-primary">View my research →</a>
        <a href="/files/cv.pdf" target="_blank" class="btn btn-ghost">Download CV</a>
        <a href="mailto:your@email.edu" class="btn btn-ghost">Get in touch</a>
      </div>
    </div>
    <div class="avatar">
      <!-- Swap initials for your photo:
           <img src="/photos/profile.jpg" alt="Nazmus Sakib" /> -->
      NS
    </div>
  </div>
</section>
