---
/**
 * EDIT HERE:
 * - title, description, tags for each card
 * - icon (any emoji works), icon background color (use CSS vars from global.css)
 * - href anchor must match the id in research.astro (e.g. #teaming)
 */

const projects = [
  {
    href: "/research#teaming",
    icon: "🤝",
    iconBg: "var(--amber-50)",
    iconColor: "var(--amber-600)",
    title: "Human-AI teaming",
    desc: "How people and AI collaborate on complex, high-stakes tasks — and where that breaks down.",
    tags: [{ label: "CHI", badge: "badge-amber" }, { label: "mixed-methods" }],
  },
  {
    href: "/research#transparency",
    icon: "🔍",
    iconBg: "var(--teal-50)",
    iconColor: "var(--teal-600)",
    title: "AI transparency",
    desc: "Designing explanations that build appropriate trust without overwhelming the user.",
    tags: [{ label: "XAI", badge: "badge-teal" }, { label: "UX research" }],
  },
  {
    href: "/research#inclusive",
    icon: "💛",
    iconBg: "var(--coral-50)",
    iconColor: "var(--coral-600)",
    title: "Inclusive interfaces",
    desc: "Participatory design methods for AI tools with and for underserved communities.",
    tags: [{ label: "PD", badge: "badge-coral" }, { label: "accessibility" }],
  },
  {
    href: "/research#mental-models",
    icon: "🧠",
    iconBg: "var(--purple-50)",
    iconColor: "var(--purple-600)",
    title: "Mental models of AI",
    desc: "How lay users form, update, and act on their understanding of AI behavior.",
    tags: [{ label: "cognitive", badge: "badge-purple" }, { label: "HCI" }],
  },
];
---
<style>
  .research-section { padding: 56px 0; border-bottom: 1px solid var(--border); }
  .section-header { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 28px; }
  .section-header a { font-size: 13px; color: var(--amber-600); }
  .section-header a:hover { text-decoration: underline; }
  .project-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px; }
  .project-card {
    background: var(--bg-surface); border: 1px solid var(--border);
    border-radius: var(--radius-lg); padding: 22px;
    transition: border-color 0.15s, transform 0.15s;
    cursor: pointer; text-decoration: none; display: block;
  }
  .project-card:hover { border-color: var(--border-hover); transform: translateY(-2px); }
  .project-icon { width: 38px; height: 38px; border-radius: var(--radius-md); display: flex; align-items: center; justify-content: center; margin-bottom: 14px; font-size: 1.15rem; }
  .project-card h3 { font-family: var(--font-display); font-size: 1rem; margin-bottom: 6px; }
  .project-card p { font-size: 13px; line-height: 1.65; margin-bottom: 14px; }
  .project-tags { display: flex; flex-wrap: wrap; gap: 6px; }
  @media (max-width: 640px) { .project-grid { grid-template-columns: 1fr; } }
</style>

<section class="research-section">
  <div class="section-header">
    <div>
      <p class="section-eyebrow">Research</p>
      <h2>What I work on</h2>
    </div>
    <a href="/research">See all projects →</a>
  </div>
  <div class="project-grid">
    {projects.map(p => (
      <a href={p.href} class="project-card">
        <div class="project-icon" style={`background:${p.iconBg};color:${p.iconColor};`}>{p.icon}</div>
        <h3>{p.title}</h3>
        <p>{p.desc}</p>
        <div class="project-tags">
          {p.tags.map(t => (
            <span class={`tag ${t.badge ?? ''}`}>{t.label}</span>
          ))}
        </div>
      </a>
    ))}
  </div>
</section>
