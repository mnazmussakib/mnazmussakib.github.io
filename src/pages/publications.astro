---
/**
 * Layout only — don't edit this file to add papers.
 * Add papers in: src/data/publications.js
 */
import Base from '../layouts/Base.astro';
import { publications } from '../data/publications.js';
---
<Base title="Publications — Md. Nazmus Sakib">
<style>
  .page-hero { padding: 64px 0 48px; border-bottom: 1px solid var(--border); margin-bottom: 48px; }
  .year-group { margin-bottom: 48px; }
  .year-label { font-family: var(--font-display); font-size: 1rem; font-weight: 500; color: var(--text-tertiary); margin-bottom: 16px; padding-bottom: 8px; border-bottom: 1px solid var(--border); }
  .pub-row { display: grid; grid-template-columns: 1fr auto; gap: 16px; align-items: start; padding: 20px 0; border-bottom: 1px solid var(--border); }
  .pub-row:last-child { border-bottom: none; }
  .pub-title { font-size: 15px; font-weight: 500; color: var(--text-primary); margin-bottom: 5px; font-family: var(--font-display); }
  .pub-authors { font-size: 13px; color: var(--text-secondary); margin-bottom: 5px; }
  .pub-authors strong { color: var(--text-primary); }
  .pub-venue { font-size: 13px; color: var(--text-tertiary); font-style: italic; display: flex; align-items: center; gap: 8px; }
  .pub-links { display: flex; flex-direction: column; gap: 6px; align-items: flex-end; flex-shrink: 0; padding-top: 4px; }
  .pub-link { font-size: 12px; font-weight: 500; color: var(--amber-600); background: var(--amber-50); border: 1px solid var(--amber-100); border-radius: 99px; padding: 3px 12px; white-space: nowrap; text-decoration: none; transition: background 0.15s; }
  .pub-link:hover { background: var(--amber-100); }
  .pub-link.ghost { background: var(--bg-muted); color: var(--text-secondary); border-color: var(--border); }
  .pub-link.ghost:hover { background: var(--border); }
  .scholar-note { background: var(--bg-muted); border-radius: var(--radius-lg); padding: 20px 24px; font-size: 14px; color: var(--text-secondary); margin-top: 16px; }
  .scholar-note a { color: var(--amber-600); text-decoration: underline; }
</style>

<div class="container">
  <div class="page-hero">
    <p class="section-eyebrow">Publications</p>
    <h1>Papers & writing</h1>
    <p style="max-width:520px;font-size:15px;margin-top:12px;">
      Peer-reviewed papers, workshop notes, and preprints. My name is bolded in author lists.
    </p>
  </div>

  {publications.map(group => (
    <div class="year-group">
      <div class="year-label">{group.year}</div>
      {group.entries.map(pub => (
        <div class="pub-row">
          <div>
            <div class="pub-title">{pub.title}</div>
            <div class="pub-authors" set:html={pub.authors.replace("Sakib, M. N.", "<strong>Sakib, M. N.</strong>")}></div>
            <div class="pub-venue">
              {pub.venue}
              {pub.badge && <span class={`tag ${pub.badge}`}>{pub.type}</span>}
              {!pub.badge && pub.type && <span class="tag">{pub.type}</span>}
            </div>
          </div>
          <div class="pub-links">
            {pub.pdf  && <a href={pub.pdf}  class="pub-link">PDF →</a>}
            {pub.code && <a href={pub.code} class="pub-link ghost">Code</a>}
            {pub.talk && <a href={pub.talk} class="pub-link ghost">Talk</a>}
          </div>
        </div>
      ))}
    </div>
  ))}

  <div class="scholar-note">
    Full list on <a href="https://scholar.google.com" target="_blank">Google Scholar</a>. Preprints available on request.
  </div>
</div>
</Base>
